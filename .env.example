# PostgreSQL connection string.
# Default points to the local Docker Compose Postgres (see docker-compose.yml).
# Swap this for a hosted Postgres (Neon, Supabase, etc.) anytime — nothing else changes.
DATABASE_URL=

# Google OAuth / app auth
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local backend AWS credentials. Prefer AWS_PROFILE locally; production should
# use an attached IAM role when running on AWS.
AWS_PROFILE=atk-store-dev

# Face Liveness runs in Tokyo because the Bangkok region does not support it.
AWS_LIVENESS_REGION=ap-northeast-1
AWS_LIVENESS_OUTPUT_BUCKET=
AWS_LIVENESS_OUTPUT_PREFIX=face-liveness/
AWS_LIVENESS_SCORE_THRESHOLD=70
AWS_LIVENESS_AUDIT_IMAGES_LIMIT=0
NEXT_PUBLIC_AWS_LIVENESS_REGION=ap-northeast-1
NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID=

# Backend-only Face Recognition collection config.
AWS_FACE_COLLECTION_ID=atk-store-face-collection-dev
AWS_FACE_MATCH_THRESHOLD=99

ENABLE_FACENESS_DEBUG=NO
ENABLE_FACE_RECOGNITION_DEBUG=NO
FACE_RECOGNITION_DEBUG_TIMEOUT_MS=5000

# Supabase Storage S3-compatible uploads.
S3_ACCESS_KEY_ID=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_SHELF_IMAGE_FOLDER=shelfs
S3_PRODUCT_IMAGE_FOLDER=inventories
S3_QR_CODE_IMAGE_FOLDER=qr-codes

# QR payload encryption.
ENCODE_KEY=

# Redis cart sync.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# IOT mock/future integration.
IOT_SERVER_URL=
IOT_WS_URL=
CLIENT_ATTENDANCE_API_KEY=
