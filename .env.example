# Load Cell Gateway API (dashboard)
NEXT_PUBLIC_LOADCELL_API_URL=/loadcell-api
NEXT_PUBLIC_LOADCELL_WS_URL=ws://localhost:8081
LOADCELL_API_URL=http://localhost:8081

# Default points to the local Docker Compose Postgres (see docker-compose.yml).
# Swap this for a hosted Postgres (Neon, Supabase, etc.) anytime — nothing else changes.
DATABASE_URL=
