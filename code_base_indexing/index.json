{
  "project": {
    "name": "atk-store",
    "version": "0.1.0",
    "description": "Mobile-first smart-shelf scan-to-shop app with Google auth, Face Liveness, and AWS Face Collection recognition",
    "language": "TypeScript",
    "sourceRoot": "src",
    "pathAlias": {
      "@/*": "src/*"
    },
    "stack": [
      "Next.js 16 (App Router)",
      "React 19",
      "Tailwind CSS v4",
      "shadcn/ui",
      "Drizzle ORM",
      "PostgreSQL",
      "Zustand",
      "Amazon Rekognition Face Liveness",
      "Amazon Rekognition Face Collection",
      "Cognito Identity Pool"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "files": [
    {
      "path": "src/db/schema.ts",
      "kind": "db-schema",
      "exports": [
        "users",
        "sessions",
        "faceLivenessAttempts",
        "userFaceProfiles",
        "shelves",
        "products",
        "shelfProducts",
        "authMethodEnum",
        "faceEnrollmentStatusEnum",
        "livenessAttemptStatusEnum",
        "faceLivenessIntentEnum",
        "faceRecognitionOutcomeEnum"
      ],
      "purpose": "Drizzle tables, enums, relations, and inferred types"
    },
    {
      "path": "src/lib/aws-liveness.ts",
      "kind": "server-only",
      "exports": [
        "getLivenessConfig",
        "getRekognitionClient",
        "getCognitoIdentityClient",
        "GOOGLE_LOGINS_KEY",
        "LivenessConfigError"
      ],
      "purpose": "Validated Face Liveness/Cognito config and AWS clients"
    },
    {
      "path": "src/lib/aws-face-recognition.ts",
      "kind": "server-only",
      "exports": [
        "getFaceRecognitionConfig",
        "getRekognitionClient",
        "FaceRecognitionConfigError"
      ],
      "purpose": "Validated Face Collection config and match threshold"
    },
    {
      "path": "src/lib/liveness-state.ts",
      "kind": "pure-util",
      "exports": [
        "decideLivenessOutcome",
        "isAttemptReusable",
        "attemptStatusForOutcome"
      ],
      "purpose": "Testable liveness state machine"
    },
    {
      "path": "src/lib/face-recognition-state.ts",
      "kind": "pure-util",
      "exports": ["createExternalImageId", "decideFaceVerification"],
      "purpose": "Testable recognition helpers for ExternalImageId and expected-user matching"
    },
    {
      "path": "src/services/face-enrollment.service.ts",
      "kind": "server-only",
      "exports": [
        "faceEnrollmentService",
        "FaceAlreadyRegisteredError",
        "FaceNotRegisteredError",
        "LivenessAttemptInProgressError",
        "LivenessAttemptNotFoundError",
        "CredentialBridgeError"
      ],
      "purpose": "Credential bridge, liveness session orchestration, result read, and recognition decision persistence"
    },
    {
      "path": "src/services/face-recognition.service.ts",
      "kind": "server-only",
      "exports": [
        "faceRecognitionService",
        "FaceReferenceImageMissingError",
        "FaceAlreadyBelongsToAnotherUserError",
        "FaceCouldNotBeIndexedError"
      ],
      "purpose": "Face Collection duplicate search, IndexFaces registration, SearchFacesByImage verification, DB mapping"
    },
    {
      "path": "src/app/api/face/credentials/route.ts",
      "kind": "route-handler",
      "exports": ["GET"],
      "purpose": "Google ID token cookie to Cognito detector credentials"
    },
    {
      "path": "src/app/api/face/session/route.ts",
      "kind": "route-handler",
      "exports": ["POST"],
      "purpose": "Create/reuse Face Liveness session for enrollment or verification intent"
    },
    {
      "path": "src/app/api/face/result/route.ts",
      "kind": "route-handler",
      "exports": ["POST"],
      "purpose": "Read owned liveness result once, then register or verify against Face Collection"
    },
    {
      "path": "src/components/face-liveness-registration.tsx",
      "kind": "client-component",
      "exports": ["FaceLivenessRegistration"],
      "purpose": "Explicit-start camera UI for enrollment; shows liveness and recognition outcomes"
    },
    {
      "path": "src/components/face-enrollment-prompt.tsx",
      "kind": "server-component",
      "exports": ["FaceEnrollmentPrompt"],
      "purpose": "Quiet post-login prompt driven by users.faceEnrollmentStatus"
    }
  ],
  "routes": {
    "pages": [
      { "path": "/", "file": "src/app/page.tsx", "rendering": "server" },
      {
        "path": "/shelf/[id]",
        "file": "src/app/shelf/[id]/page.tsx",
        "rendering": "server"
      },
      {
        "path": "/cart",
        "file": "src/app/cart/page.tsx",
        "rendering": "client"
      },
      {
        "path": "/signin",
        "file": "src/app/signin/page.tsx",
        "rendering": "server"
      },
      {
        "path": "/register-face",
        "file": "src/app/register-face/page.tsx",
        "rendering": "server"
      }
    ],
    "api": [
      {
        "method": "GET",
        "path": "/api/shelf/[id]",
        "file": "src/app/api/shelf/[id]/route.ts"
      },
      {
        "method": "GET",
        "path": "/api/auth/signin/google",
        "file": "src/app/api/auth/signin/google/route.ts"
      },
      {
        "method": "GET",
        "path": "/api/auth/callback/google",
        "file": "src/app/api/auth/callback/google/route.ts"
      },
      {
        "method": "POST",
        "path": "/api/auth/signout",
        "file": "src/app/api/auth/signout/route.ts"
      },
      {
        "method": "GET",
        "path": "/api/face/credentials",
        "file": "src/app/api/face/credentials/route.ts"
      },
      {
        "method": "POST",
        "path": "/api/face/session",
        "file": "src/app/api/face/session/route.ts",
        "body": { "intent": "optional: enrollment | verification" }
      },
      {
        "method": "POST",
        "path": "/api/face/result",
        "file": "src/app/api/face/result/route.ts",
        "body": { "sessionId": "string" }
      }
    ],
    "proxy": {
      "file": "src/proxy.ts",
      "purpose": "Optimistic page auth redirect; API routes must call requireCurrentUser themselves"
    }
  },
  "dataModel": {
    "tables": [
      "users",
      "sessions",
      "face_liveness_attempts",
      "user_face_profiles",
      "shelves",
      "products",
      "shelf_products"
    ],
    "enums": {
      "auth_method": ["google", "facebook", "line", "apple", "credentials"],
      "face_enrollment_status": ["not_registered", "pending", "registered"],
      "liveness_attempt_status": [
        "pending",
        "succeeded",
        "failed",
        "expired",
        "cancelled"
      ],
      "face_liveness_intent": ["enrollment", "verification"],
      "face_recognition_outcome": [
        "registered",
        "verified",
        "mismatch",
        "duplicate",
        "not_indexed"
      ]
    },
    "recognitionMapping": {
      "table": "user_face_profiles",
      "ownerKey": "user_id",
      "awsCollectionKey": "collection_id",
      "awsFaceKey": "face_id",
      "note": "Application DB stores Rekognition IDs and ownership metadata, not face vectors."
    }
  },
  "faceRecognitionFlow": {
    "enrollment": [
      "CreateFaceLivenessSession",
      "StartFaceLivenessSession",
      "GetFaceLivenessSessionResults",
      "SearchFacesByImage duplicate check",
      "IndexFaces when no existing match",
      "Insert user_face_profiles and mark user registered"
    ],
    "verification": [
      "Create/reuse liveness session with intent=verification",
      "GetFaceLivenessSessionResults",
      "SearchFacesByImage",
      "Map FaceId through user_face_profiles",
      "Accept only when matched userId equals current user and similarity >= AWS_FACE_MATCH_THRESHOLD"
    ]
  },
  "auth": {
    "provider": "google",
    "sessionCookie": "atk_session",
    "sessionStrategy": "database opaque token in httpOnly cookie; SHA-256 hash at rest",
    "faceCredentialBridge": "path-scoped Google ID token cookie -> Cognito Identity Pool -> StartFaceLivenessSession-scoped temporary credentials"
  },
  "envKeys": [
    "DATABASE_URL",
    "AUTH_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "AWS_PROFILE",
    "AWS_LIVENESS_REGION",
    "AWS_LIVENESS_OUTPUT_BUCKET",
    "AWS_LIVENESS_OUTPUT_PREFIX",
    "AWS_LIVENESS_SCORE_THRESHOLD",
    "AWS_LIVENESS_AUDIT_IMAGES_LIMIT",
    "NEXT_PUBLIC_AWS_LIVENESS_REGION",
    "NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID",
    "AWS_FACE_COLLECTION_ID",
    "AWS_FACE_MATCH_THRESHOLD"
  ],
  "todos": [
    {
      "tag": "payment",
      "where": "src/app/cart/page.tsx",
      "desc": "Real checkout / payment"
    },
    {
      "tag": "order",
      "where": "src/app/cart/page.tsx",
      "desc": "Persist client cart to order table"
    }
  ]
}
