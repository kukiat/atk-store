APP_PORT=8081
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DB_HOST=postgres.hexdas.cloud
DB_PORT=5432
DB_USER=atkadmin
DB_PASSWORD=your-db-password
DB_NAME=atkstore
DB_SSLMODE=disable

# Redis — ใช้ REDIS_URL (แนะนำ) รองรับ redis:// และ rediss://
#
# ภายใน Docker (service name "redis", ไม่ใช้ TLS):
# REDIS_URL=redis://:P%40ssr3d%21@redis:6379
#
# จากภายนอก (ต้องใช้ rediss:// + TLS เสมอ):
REDIS_URL=rediss://:P%40ssr3d%21@redis.hexdas.cloud:6379
#
# ทางเลือก: แยกค่า (ต้องตั้ง REDIS_TLS=true สำหรับภายนอก)
# REDIS_ADDR=redis.hexdas.cloud:6379
# REDIS_PASSWORD=P@ssr3d!
# REDIS_TLS=true

# Encrypt MQTT passwords at rest (AES-256-GCM)
ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Auth (Step 13) — ตั้ง AUTH_ENABLED=false ใน dev ถ้าไม่ต้อง login
AUTH_ENABLED=true
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_EXPIRY_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# --- Hexdas RabbitMQ MQTT (optional — สำหรับ scripts/seed-hexdas-mqtt.sh) ---
# Gateway / ESP32 / Node-RED ใช้ MQTT TCP + TLS (ไม่ใช่ WebSocket หรือ AMQP)
# MQTT_SEED_NAME=hexdas-rabbitmq
# MQTT_SEED_HOST=mqtt.hexdas.cloud
# MQTT_SEED_PORT=1883
# MQTT_SEED_USERNAME=rabbitmqadmin
# MQTT_SEED_PASSWORD=your-mqtt-password
